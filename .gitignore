# ─────────────────────────────────────────────────────────────
#  POPPY — .gitignore
# ─────────────────────────────────────────────────────────────


# ── Secrets & credentials ─────────────────────────────────────
# Never commit these. Use --dart-define or CI environment vars.
.env
.env.*
*.env
dart_defines/
secrets.dart
lib/core/secrets.dart

# Android signing — if you ever add a keystore for release
android/key.properties
*.keystore
*.jks

# Google services (if you add Firebase later)
google-services.json
GoogleService-Info.plist


# ── Machine-local Android config ─────────────────────────────
# Contains your local SDK path (e.g. D:\SWDevelopment\SDKs\...)
# Every developer/machine has a different one.
android/local.properties


# ── Flutter / Dart generated files ───────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/
**/doc/api/
**/ios/Flutter/.last_build_id


# ── Android build artifacts ───────────────────────────────────
/android/app/debug/
/android/app/profile/
/android/app/release/
android/.gradle/
android/build/
android/.kotlin/
*.apk
*.aab


# ── iOS build artifacts ───────────────────────────────────────
ios/Pods/
ios/.symlinks/
ios/Flutter/App.framework
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/ephemeral/
ios/Flutter/app.flx
ios/Flutter/app.zip
ios/Flutter/flutter_assets/
*.ipa


# ── macOS ─────────────────────────────────────────────────────
.DS_Store
macos/Pods/
macos/Flutter/GeneratedPluginRegistrant.swift
macos/Flutter/ephemeral/


# ── IDE ───────────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.swp
.atom/
.history/
.svn/
.swiftpm/


# ── Logs & misc ───────────────────────────────────────────────
*.log
*.class
*.pyc
migrate_working_dir/
.buildlog/
.build/
app.*.symbols
app.*.map.json


# ── Crash / debug outputs ─────────────────────────────────────
*.hprof
nohup.out
